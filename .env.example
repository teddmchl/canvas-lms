# Core - Connects the database and secures user sessions
MONGODB_URI="mongodb+srv://<USER>:<PASSWORD>@<CLUSTER>.mongodb.net/<DBNAME>"
JWT_SECRET="<YOUR_64_CHAR_HEX_SECRET>"

# High-Performance Storage (Required for file uploads on Vercel)
# After deploying to Vercel, go to the "Storage" tab -> "Blob" to activate this.
BLOB_READ_WRITE_TOKEN="..."

# Communications (Optional Email Support)
SMTP_HOST="smtp.provider.com"
SMTP_PORT=587
SMTP_USER="api-key"
SMTP_PASS="secret-key"
EMAIL_FROM="Canvas LMS <noreply@yourdomain.com>"

# App Identity
NEXT_PUBLIC_APP_URL="https://yourpage.vercel.app"
